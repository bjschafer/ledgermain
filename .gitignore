# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Raw Foundry clone — fetched on demand at the pinned SHA, never committed.
# (The *normalized* JSON output under packages/data-pipeline/data/ IS committed.)
.cache/
packages/data-pipeline/.cache/

# Web app: RefData copied from data-pipeline at predev/prebuild (source of truth
# stays in packages/data-pipeline/data/). Don't commit the duplicate.
apps/web/public/data/
# License/notice copies copied from repo root at predev/prebuild by
# scripts/copy-refdata.ts -- don't commit these duplicates.
apps/web/public/OGL.txt
apps/web/public/NOTICE.md
apps/web/public/LICENSE

# Playwright e2e artifacts (browsers are cached globally, not in-repo)
test-results/
playwright-report/
blob-report/
.playwright/

# Wrangler local dev state (Miniflare's local KV/D1/etc. simulation) and
# per-developer local secrets (`wrangler secret put` equivalent for
# `wrangler dev` — see apps/api/README.md). Never commit real secrets.
.wrangler/
.dev.vars

# Vite per-developer env overrides (e.g. apps/web/.env.local with a real
# VITE_API_URL) — see apps/web/.env.example for the committed template.
.env.local
.env.*.local

# Editor / OS
.DS_Store
.idea/
.vscode/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Claude Code: worktrees and machine/session-local state stay untracked.
# Shared config (e.g. .claude/skills/) is committed.
.claude/worktrees/
.claude/settings.local.json
.claude/scheduled_tasks.lock
