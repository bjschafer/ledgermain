# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Raw Foundry clone — fetched on demand at the pinned SHA, never committed.
# (The *normalized* JSON output under packages/data-pipeline/data/ IS committed.)
.cache/
packages/data-pipeline/.cache/

# Web app: RefData copied from data-pipeline at predev/prebuild (source of truth
# stays in packages/data-pipeline/data/). Don't commit the duplicate.
apps/web/public/data/
# License/notice copies copied from repo root at predev/prebuild by
# scripts/copy-refdata.ts -- don't commit these duplicates.
apps/web/public/OGL.txt
apps/web/public/NOTICE.md
apps/web/public/LICENSE

# Playwright e2e artifacts (browsers are cached globally, not in-repo)
test-results/
playwright-report/
blob-report/
.playwright/

# Editor / OS
.DS_Store
.idea/
.vscode/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

.claude/
