{
  "name": "ledgermain",
  "version": "0.0.0",
  "private": true,
  "description": "Pathfinder 1e in-play character tracker and builder (monorepo root).",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --filter @pf1/web dev",
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "typecheck": "bun run --filter '*' typecheck",
    "e2e": "bun run --filter @pf1/web e2e",
    "data:fetch": "bun run --filter @pf1/data-pipeline fetch",
    "data:build": "bun run --filter @pf1/data-pipeline generate"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
