{
  "name": "@pf1/data-pipeline",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "Fetches the pinned Foundry PF1 YAML packs and emits normalized, versioned JSON reference data. The fetch/generate scripts are MIT; the vendored normalized data under ./data/ is Open Game Content governed by the repo-root OGL.txt.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "fetch": "bun src/cli/fetch.ts",
    "generate": "bun src/cli/generate.ts",
    "build:data": "bun src/cli/fetch.ts && bun src/cli/generate.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@pf1/schema": "workspace:*",
    "csv-parse": "^7.0.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "^22"
  }
}
